window.abrirImportarContrachequesRh = function () {

    const modal = document.getElementById("modalImportarContrachequesRh");

    if (!modal) {
        alert("Modal modalImportarContrachequesRh não encontrado.");
        return;
    }

    modal.style.display = "flex";

    const input = document.getElementById("arquivoContrachequesRh");

    if (input && !input.dataset.evento) {

        input.dataset.evento = "ok";

        input.addEventListener("change", function () {

            if (this.files.length === 0) return;

            document.getElementById("nomeArquivoContracheques").innerHTML =
                "📄 " + this.files[0].name;

        });

    }

};
async function enviarArquivoContrachequesRh() {

    const arquivo =
        document.getElementById("arquivoContrachequesRh").files[0];

    const status =
        document.getElementById("statusImportacaoContracheques");

    if (!arquivo) {

        status.innerHTML = "Selecione um PDF.";

        return;

    }

    status.innerHTML = "⏳ Preparando PDF...";

    try {

        const base64 =
            await converterArquivoParaBase64Rh(arquivo);

        status.innerHTML = "⏳ Enviando PDF...";

        const payload = {

            action: "uploadImportacaoContracheques",

            nomeArquivo: arquivo.name,

            arquivoBase64: base64

        };

        const resposta = await fetch(API_URL, {

            method: "POST",

            body: JSON.stringify(payload)

        });

        const dados = await resposta.json();

        if(dados.sucesso){

            status.innerHTML =
                "✅ " + dados.mensagem;

        }else{

            status.innerHTML =
                "❌ " + dados.mensagem;

        }

    }catch(e){

        console.error(e);

        status.innerHTML =
            "❌ " + e.toString();

    }

}
function limparImportacaoContrachequesRh(){

    const arquivo =
        document.getElementById("arquivoContrachequesRh");

    const nome =
        document.getElementById("nomeArquivoContracheques");

    const status =
        document.getElementById("statusImportacaoContracheques");

    if(arquivo) arquivo.value = "";

    if(nome){

        nome.innerHTML =
            "Nenhum arquivo selecionado.";

    }

    if(status){

        status.innerHTML = "";

    }

}
function fecharImportacaoContrachequesRh(){

    limparImportacaoContrachequesRh();

    fecharModalRh(
        "modalImportarContrachequesRh"
    );

}
